generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  role          UserRole     @default(USER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bio           String?
  githubUrl     String?
  linkedinUrl   String?
  title         String?
  websiteUrl    String?
  accounts      Account[]
  invitations   Invitation[]
  sessions      Session[]
  projects      Project[]    @relation("ProjectToUser")

  @@index([createdAt])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  userId    String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@map("invitations")
}

model Project {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  content       String?
  coverImage    String?
  images        String[]
  liveUrl       String?
  githubUrl     String?
  startDate     DateTime
  endDate       DateTime?
  isFeatured    Boolean       @default(false)
  isVisible     Boolean       @default(true)
  status        ProjectStatus @default(Planned)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  categories    Category[]    @relation("CategoryToProject")
  technologies  Technology[]  @relation("ProjectToTechnology")
  collaborators User[]        @relation("ProjectToUser")

  @@index([createdAt])
  @@index([updatedAt])
  @@map("projects")
}

model Technology {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  category  String    @default("Other")
  projects  Project[] @relation("ProjectToTechnology")

  @@map("technologies")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[] @relation("CategoryToProject")

  @@map("categories")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("posts")
}

model AssistantConfig {
  id               String   @id @default("default")
  enabled          Boolean  @default(true)
  name             String   @default("Moaaz")
  greeting         String   @default("Hey! I'm Moaaz's AI twin. Ask me anything about him — skills, projects, experience, or what he's working on.")
  systemPrompt     String?
  refusalMessage   String   @default("I can only answer questions about Moaaz — his work, skills, projects, and experience. Try asking something about him!")
  suggestedPrompts String[]
  providerMode     String   @default("hosted")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("assistant_config")
}

model AssistantKnowledge {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String
  priority  Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([enabled, priority])
  @@map("assistant_knowledge")
}

model ChatSession {
  id             String        @id @default(cuid())
  visitorId      String?
  pagePath       String?
  userAgent      String?
  provider       String?
  model          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  browserName    String?
  browserVersion String?
  city           String?
  country        String?
  deviceType     String?
  ipAddress      String?
  osName         String?
  osVersion      String?
  referrer       String?
  region         String?
  messages       ChatMessage[]

  @@index([createdAt])
  @@index([visitorId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  isRefusal Boolean     @default(false)
  topic     String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@index([isRefusal])
  @@map("chat_messages")
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  alt         String
  url         String
  width       Int?
  height      Int?
  category    String   @default("general")
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible, order])
  @@index([category])
  @@map("gallery_images")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

model MeetingSlot {
  id        String          @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  timezone  String          @default("Asia/Karachi")
  isBooked  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  booking   MeetingBooking?

  @@unique([date, startTime])
  @@index([date, isBooked])
  @@map("meeting_slots")
}

model MeetingBooking {
  id        String      @id @default(cuid())
  slotId    String      @unique
  name      String
  email     String
  company   String?
  message   String?
  timezone  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  slot      MeetingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([createdAt])
  @@map("meeting_bookings")
}

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  Planned
  Under_Development
  Completed
  On_Hold
  Cancelled
}
